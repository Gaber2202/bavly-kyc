# =============================================================================
# Bavly KYC — production-oriented example (.env is never committed)
# Full checklist: docs/DEPLOYMENT.md
# =============================================================================

APP_NAME="Bavly KYC"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
# No trailing slash; must match the URL users open (HTTPS in production)
APP_URL=https://your-domain.com

# Comma-separated proxy IPs, or * behind Hostinger / load balancers / CDNs
TRUSTED_PROXIES=*

# Analytics dashboard cache (seconds). 0 = no cache.
ANALYTICS_CACHE_TTL=60

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_EG
APP_TIMEZONE=Africa/Cairo

# Set before first db:seed in production, then rotate password in UI
SEED_ADMIN_PASSWORD=

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

# production: error + stack; rotate / monitor storage/logs/laravel.log
LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=error

DB_CONNECTION=mysql
# Hostinger: copy exact host from hPanel (may differ from 127.0.0.1)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bavly_kyc
DB_USERNAME=
DB_PASSWORD=

# database = requires migrations (sessions table). file = ok for single-server dev only.
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# true when the site is served only over HTTPS
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# sync = no background worker (recommended Hostinger shared). database = use with queue:work on VPS.
QUEUE_CONNECTION=sync

CACHE_STORE=database

# Set real provider when you need outbound mail
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"
